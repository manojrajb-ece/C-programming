#include <stdio.h>

int main()
{
    int age;
    char id;

    printf("Enter your age \n");
    scanf("%d", &age);

    if (age < 18)
    {
        printf("You are not eligible for voting \n");
    }

    else if (age == 18)
    {
        printf("Do you have voter id, if you have press 'y' \n");
        scanf(" %c", &id);

        if (id == 'y')
        {
            printf("You are eligible for voting \n");
        }
        else
        {
            printf("Apply for voter id \n");
        }
    }

    else if (age > 18)
    {
        printf("Do you have voter id, if you have press 'y' \n");
        scanf(" %c", &id);

        if (id == 'y')
        {
            printf("You are eligible for voting \n");
        }
        else
        {
            printf("You are not eligible for voting \n");
        }
    }

    return 0;
}
